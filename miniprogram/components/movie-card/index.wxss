.movie-card {
  width: 200rpx;
  display: flex;
  flex-direction: column;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 6rpx 6rpx 12rpx #c8d8e8, -6rpx -6rpx 12rpx #ffffff;
}

.movie-card-small {
  width: 160rpx;
}

.movie-poster {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(145deg, #e0e8f0, #f0f4f8);
}

.movie-card-small .movie-poster {
  height: 220rpx;
}

.movie-info {
  padding: 16rpx;
}

.movie-title {
  font-size: 26rpx;
  color: #5a6a7a;
  font-weight: 400;
  line-height: 1.4;
}

.movie-card-small .movie-title {
  font-size: 24rpx;
}

.movie-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.movie-rating {
  font-size: 24rpx;
  background: linear-gradient(135deg, #f8b4c4, #a8d4f0);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 500;
}

.movie-year {
  font-size: 22rpx;
  color: #9aa8b8;
  margin-left: 12rpx;
  font-weight: 300;
}

.movie-tags {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
}

.movie-tags .tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  margin-right: 6rpx;
  margin-bottom: 4rpx;
  color: #8a9aaa;
  background: linear-gradient(145deg, #f5faff, #e8f0f0);
  border-radius: 16rpx;
  box-shadow: 2rpx 2rpx 4rpx #d0dae4, -2rpx -2rpx 4rpx #ffffff;
}
