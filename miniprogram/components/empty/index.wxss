.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c8d8e8, -6rpx -6rpx 12rpx #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.8;
}

.empty-text {
  font-size: 26rpx;
  color: #9aa8b8;
  font-weight: 300;
}
