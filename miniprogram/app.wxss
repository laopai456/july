page {
  background: linear-gradient(135deg, #e8f4fc 0%, #fce8f0 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #7a8b9a;
  box-sizing: border-box;
}

view, text, image {
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
}

.text-center {
  text-align: center;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.neumorphic {
  background: linear-gradient(145deg, #f0f8ff, #e0e8f0);
  box-shadow: 8rpx 8rpx 16rpx #d0d8e0, -8rpx -8rpx 16rpx #ffffff;
  border-radius: 24rpx;
}

.neumorphic-inset {
  background: linear-gradient(145deg, #e0e8f0, #f0f8ff);
  box-shadow: inset 4rpx 4rpx 8rpx #d0d8e0, inset -4rpx -4rpx 8rpx #ffffff;
  border-radius: 24rpx;
}

.neumorphic-btn {
  background: linear-gradient(145deg, #ffd0e0, #d0e8ff);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
  border-radius: 40rpx;
  color: #ffffff;
  font-weight: 300;
  letter-spacing: 2rpx;
}

.neumorphic-btn:active {
  box-shadow: inset 4rpx 4rpx 8rpx #b0c0d0, inset -4rpx -4rpx 8rpx #f0f0ff;
}

.rating {
  color: #f0a0b8;
  font-weight: 400;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f8);
  box-shadow: 3rpx 3rpx 6rpx #d8e0e8, -3rpx -3rpx 6rpx #ffffff;
  color: #8a9aaa;
  margin-right: 10rpx;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-text {
  color: #9aa8b8;
  font-size: 24rpx;
  margin-left: 10rpx;
}
