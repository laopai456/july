<view class="container">
  <view class="card">
    <text class="title">调试工具</text>
    <text class="subtitle">数据已改为实时获取</text>
  </view>

  <view class="section">
    <text class="section-title">数据源说明</text>
    <text class="hint">• 综艺/国产剧: 豆瓣API (云函数)</text>
    <text class="hint">• 电影/韩剧/日剧: TMDB API</text>
    <text class="hint">• 数据实时获取，无需导入</text>
  </view>

  <view class="section">
    <text class="section-title">连接测试</text>
    <button class="btn" bindtap="testTMDB" size="mini">测试TMDB</button>
    <button class="btn" bindtap="testDouban" size="mini">测试豆瓣</button>
  </view>

  <view class="section">
    <text class="section-title">缓存管理</text>
    <button class="btn-primary" bindtap="clearAllCache">清除缓存</button>
    <text class="hint">清除后下拉刷新首页即可重新获取数据</text>
  </view>

  <view class="log" wx:if="{{logs.length > 0}}">
    <text class="log-title">操作日志</text>
    <text class="log-item" wx:for="{{logs}}" wx:key="*this">{{item}}</text>
  </view>
</view>
