<view class="container">
  <view class="card">
    <text class="title">调试工具</text>
    <text class="subtitle">数据源：TMDB API</text>
  </view>

  <view class="section">
    <text class="section-title">数据源说明</text>
    <text class="hint">• 所有数据来自TMDB API</text>
    <text class="hint">• 支持完整数据：类型/演员/导演/简介</text>
    <text class="hint">• 数据质量高，更新及时</text>
  </view>

  <view class="section">
    <text class="section-title">功能测试</text>
    <button class="btn" bindtap="testTMDBVariety" size="mini">测试综艺</button>
    <button class="btn" bindtap="testTMDBMovie" size="mini">测试电影</button>
    <button class="btn" bindtap="testTMDBKDrama" size="mini">测试韩剧</button>
  </view>

  <view class="section">
    <text class="section-title">缓存管理</text>
    <button class="btn-primary" bindtap="clearAllCache">清除所有缓存</button>
    <text class="hint">清除后下拉刷新首页即可重新获取数据</text>
  </view>

  <view class="log" wx:if="{{logs.length > 0}}">
    <text class="log-title">操作日志</text>
    <text class="log-item" wx:for="{{logs}}" wx:key="*this">{{item}}</text>
  </view>
</view>
