<view class="container">
  <view class="card">
    <text class="title">数据管理</text>
    <text class="subtitle">批量导入影视数据</text>
  </view>

  <view class="section">
    <text class="section-title">数据状态</text>
    <text class="status-text">总计: {{totalCount}} 条</text>
    <text class="status-text">综艺: {{varietyCount}} | 电影: {{movieCount}} | 热剧: {{dramaCount}}</text>
    <button class="btn" bindtap="checkDataStatus" size="mini">刷新状态</button>
  </view>

  <view class="section">
    <text class="section-title">导入数据</text>
    <button class="btn-primary" bindtap="importAll" loading="{{allLoading}}">
      导入全部数据
    </button>
    <text class="hint">综艺10条 + 电影10条 + 热剧10条 = 30条</text>
  </view>

  <view class="section">
    <text class="section-title">清空数据</text>
    <text class="hint">请到云开发控制台操作：</text>
    <text class="hint">1. 点击顶部「云开发」按钮</text>
    <text class="hint">2. 数据库 → 右键 movies → 删除集合</text>
    <text class="hint">3. 重新创建 movies 集合</text>
  </view>

  <view class="log" wx:if="{{logs.length > 0}}">
    <text class="log-title">操作日志</text>
    <text class="log-item" wx:for="{{logs}}" wx:key="*this">{{item}}</text>
  </view>
</view>
