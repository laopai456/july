.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #e8f4fc 0%, #fce8f0 100%);
  padding: 30rpx;
}

.card {
  padding: 40rpx;
  margin-bottom: 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 8rpx 8rpx 20rpx #c8d8e8, -8rpx -8rpx 20rpx #ffffff;
  text-align: center;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 300;
  color: #5a6a7a;
  letter-spacing: 2rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #9aa8b8;
  margin-top: 10rpx;
  font-weight: 300;
}

.section {
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c8d8e8, -6rpx -6rpx 12rpx #ffffff;
}

.section-title {
  display: block;
  font-size: 28rpx;
  color: #6a7a8a;
  margin-bottom: 20rpx;
  font-weight: 400;
}

.btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #6a7a8a;
  background: linear-gradient(145deg, #f5faff, #e8f0f0);
  border-radius: 40rpx;
  box-shadow: 4rpx 4rpx 8rpx #d0dae4, -4rpx -4rpx 8rpx #ffffff;
}

.btn-primary {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #b8d4f0, #f0b8c8);
  border-radius: 40rpx;
  box-shadow: 4rpx 4rpx 8rpx #d0dae4, -4rpx -4rpx 8rpx #ffffff;
}

.btn-warning {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #f0b8b8, #f0c8b8);
  border-radius: 40rpx;
  box-shadow: 4rpx 4rpx 8rpx #d0dae4, -4rpx -4rpx 8rpx #ffffff;
}

.hint {
  display: block;
  font-size: 22rpx;
  color: #9aa8b8;
  margin-top: 12rpx;
}

.status-text {
  display: block;
  font-size: 26rpx;
  color: #6a7a8a;
  margin-bottom: 12rpx;
}

.btn[disabled] {
  opacity: 0.6;
}

.progress {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #8a9aaa;
  margin-top: 16rpx;
}

.log {
  padding: 30rpx;
  margin-top: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c8d8e8, -6rpx -6rpx 12rpx #ffffff;
}

.log-title {
  display: block;
  font-size: 26rpx;
  color: #6a7a8a;
  margin-bottom: 16rpx;
  font-weight: 400;
}

.log-item {
  display: block;
  font-size: 22rpx;
  color: #9aa8b8;
  line-height: 1.8;
  font-family: monospace;
}
