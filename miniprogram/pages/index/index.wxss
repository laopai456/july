.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #e8f4fc 0%, #fce8f0 100%);
  padding: 30rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}

.tabs {
  display: flex;
  justify-content: center;
  flex: 1;
  padding: 0 20rpx;
}

.debug-btn {
  font-size: 22rpx;
  color: #9aa8b8;
  padding: 12rpx 20rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 20rpx;
  box-shadow: 3rpx 3rpx 6rpx #d0d8e0, -3rpx -3rpx 6rpx #ffffff;
  margin-right: 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #9aa8b8;
  padding: 24rpx 0;
  position: relative;
  transition: all 0.3s ease;
  border-radius: 20rpx;
  margin: 0 10rpx;
}

.tab-item.active {
  color: #7a8b9a;
  font-weight: 500;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
}

.sub-tabs {
  display: flex;
  padding: 20rpx 30rpx;
  background: transparent;
}

.sub-item {
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #9aa8b8;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 30rpx;
  box-shadow: 4rpx 4rpx 8rpx #d0d8e0, -4rpx -4rpx 8rpx #ffffff;
  transition: all 0.3s ease;
}

.sub-item.active {
  color: #ffffff;
  background: linear-gradient(145deg, #a8b4fc, #f0a0b8);
  box-shadow: inset 3rpx 3rpx 6rpx #d0d8e0, inset -3rpx -3rpx 6rpx #ffffff;
}

.list-container {
  padding: 10rpx 20rpx;
}

.movie-list {
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 8rpx 8rpx 16rpx #d0d8e0, -8rpx -8rpx 16rpx #ffffff;
}

.movie-item {
  display: flex;
  padding: 24rpx;
  margin: 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
  transition: all 0.3s ease;
}

.movie-item:active {
  box-shadow: inset 4rpx 4rpx 8rpx #d0d8e0, inset -4rpx -4rpx 8rpx #ffffff;
}

.rank {
  width: 56rpx;
  height: 56rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #9aa8b8;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 4rpx 4rpx 8rpx #d0d8e0, -4rpx -4rpx 8rpx #ffffff;
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.movie-item:nth-child(1) .rank,
.movie-item:nth-child(2) .rank,
.movie-item:nth-child(3) .rank {
  color: #ffffff;
  background: linear-gradient(145deg, #ffb6c0, #f0a0b8);
  box-shadow: 4rpx 4rpx 8rpx #e8a0a0, -4rpx -4rpx 8rpx #ffffff;
}

.poster-wrap {
  width: 120rpx;
  height: 160rpx;
  margin: 0 16rpx;
}

.poster {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #e8f0f0, #f0f8ff);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
}

.poster-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #e0e8f0, #f0e8f0);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-placeholder text {
  font-size: 48rpx;
  color: #b0c0d0;
  font-weight: 300;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 400;
  color: #5a6a7a;
  max-width: 340rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rating {
  font-size: 28rpx;
  color: #f0a0b8;
  font-weight: 500;
}

.meta {
  font-size: 24rpx;
  color: #9aa8b8;
  margin-bottom: 12rpx;
}

.meta text {
  margin-right: 16rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: #8a9aaa;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  margin-bottom: 6rpx;
  box-shadow: 2rpx 2rpx 4rpx #d0d8e0, -2rpx -2rpx 4rpx #ffffff;
}

.loading-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.loading-text {
  font-size: 36rpx;
  color: #8a9aaa;
}

.emoji-bounce {
  width: 60rpx;
  height: 60rpx;
  margin-left: 8rpx;
  animation: bounce 0.6s ease-in-out infinite;
}

.emoji-bounce.delay-1 {
  animation-delay: 0.2s;
}

.emoji-bounce.delay-2 {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #9aa8b8;
  font-size: 24rpx;
}

.empty {
  text-align: center;
  padding: 100rpx;
  color: #9aa8b8;
  font-size: 28rpx;
}
