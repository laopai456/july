.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #e8f4fc 0%, #fce8f0 100%);
  padding: 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: transparent;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 50%;
  box-shadow: 4rpx 4rpx 8rpx #d0d8e0, -4rpx -4rpx 8rpx #ffffff;
}

.search-btn text {
  font-size: 28rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 0 30rpx 20rpx;
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 30rpx;
  box-shadow: inset 3rpx 3rpx 6rpx #d0d8e0, inset -3rpx -3rpx 6rpx #ffffff;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #5a6a7a;
}

.search-clear {
  font-size: 28rpx;
  color: #9aa8b8;
  padding: 8rpx;
}

.search-cancel {
  font-size: 28rpx;
  color: #8a9aaa;
}

.tabs {
  display: flex;
  justify-content: center;
  flex: 1;
  padding: 0 20rpx;
}

.debug-btn {
  font-size: 22rpx;
  color: #9aa8b8;
  padding: 12rpx 20rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 20rpx;
  box-shadow: 3rpx 3rpx 6rpx #d0d8e0, -3rpx -3rpx 6rpx #ffffff;
  margin-right: 10rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 30rpx;
  color: #9aa8b8;
  padding: 24rpx 0;
  position: relative;
  transition: all 0.3s ease;
  border-radius: 20rpx;
  margin: 0 10rpx;
}

.tab-item.active {
  color: #7a8b9a;
  font-weight: 500;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
}

.sub-tabs {
  display: flex;
  padding: 20rpx 30rpx;
  background: transparent;
}

.sub-item {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #9aa8b8;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 30rpx;
  box-shadow: 4rpx 4rpx 8rpx #d0d8e0, -4rpx -4rpx 8rpx #ffffff;
  transition: all 0.3s ease;
}

.sub-name {
  margin-right: 8rpx;
}

.sub-count {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #b8d4f0, #f0b8c8);
  border-radius: 18rpx;
  text-align: center;
}

.sub-item.active {
  color: #ffffff;
  background: linear-gradient(145deg, #a8b4fc, #f0a0b8);
  box-shadow: inset 3rpx 3rpx 6rpx #d0d8e0, inset -3rpx -3rpx 6rpx #ffffff;
}

.sub-item.active .sub-count {
  background: rgba(255, 255, 255, 0.3);
  color: #ffffff;
}

.list-container {
  padding: 10rpx 20rpx;
}

.movie-list {
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 8rpx 8rpx 16rpx #d0d8e0, -8rpx -8rpx 16rpx #ffffff;
}

.movie-item {
  display: flex;
  padding: 24rpx;
  margin: 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
  transition: all 0.3s ease;
}

.movie-item:active {
  box-shadow: inset 4rpx 4rpx 8rpx #d0d8e0, inset -4rpx -4rpx 8rpx #ffffff;
}

.rank {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #9aa8b8;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 4rpx 4rpx 8rpx #d0d8e0, -4rpx -4rpx 8rpx #ffffff;
  border-radius: 16rpx;
  margin-right: 16rpx;
}

.movie-item:nth-child(1) .rank,
.movie-item:nth-child(2) .rank,
.movie-item:nth-child(3) .rank {
  color: #ffffff;
  background: linear-gradient(145deg, #ffb6c0, #f0a0b8);
  box-shadow: 4rpx 4rpx 8rpx #e8a0a0, -4rpx -4rpx 8rpx #ffffff;
}

.poster-wrap {
  width: 120rpx;
  height: 160rpx;
  flex-shrink: 0;
  margin: 0 16rpx;
}

.poster {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #e8f0f0, #f0f8ff);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
}

.poster-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #e0e8f0, #f0e8f0);
  box-shadow: 6rpx 6rpx 12rpx #c0d0e0, -6rpx -6rpx 12rpx #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster-placeholder text {
  font-size: 48rpx;
  color: #b0c0d0;
  font-weight: 300;
}

.info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  min-width: 0;
  margin-bottom: 8rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 400;
  color: #5a6a7a;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 6rpx;
  margin-left: 12rpx;
}

.meta {
  font-size: 24rpx;
  color: #9aa8b8;
  margin-bottom: 8rpx;
}

.meta text {
  margin-right: 16rpx;
}

.cast-row {
  margin-bottom: 4rpx;
}

.cast-text {
  font-size: 22rpx;
  color: #8a9aaa;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.hot-score {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #ff6b6b, #ffa500);
  padding: 2rpx 10rpx;
  border-radius: 12rpx;
}

.hot-icon {
  font-size: 16rpx;
  margin-right: 2rpx;
}

.hot-value {
  font-size: 18rpx;
  color: #ffffff;
  font-weight: 600;
}

.rating {
  font-size: 22rpx;
  color: #f0a0b8;
  font-weight: 500;
}

.loading-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx;
}

.loading-text {
  font-size: 36rpx;
  color: #8a9aaa;
}

.emoji-bounce {
  width: 60rpx;
  height: 60rpx;
  margin-left: 8rpx;
  animation: bounce 0.6s ease-in-out infinite;
}

.emoji-bounce.delay-1 {
  animation-delay: 0.2s;
}

.emoji-bounce.delay-2 {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #9aa8b8;
  font-size: 24rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #8a9aaa;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #a0b0c0;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #a8b4fc, #f0a0b8);
  border-radius: 30rpx;
  box-shadow: 4rpx 4rpx 8rpx #d0d8e0, -4rpx -4rpx 8rpx #ffffff;
}

.refresh-time {
  text-align: center;
  padding: 20rpx;
  margin-top: 20rpx;
}

.refresh-time text {
  font-size: 22rpx;
  color: #a0b0c0;
}
