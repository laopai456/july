<view class="container" wx:if="{{!showDetailCard}}">
  <view class="header">
    <view class="tabs">
      <view 
        class="tab-item {{currentTab === index ? 'active' : ''}}" 
        wx:for="{{tabs}}" 
        wx:key="index"
        data-index="{{index}}"
        bindtap="onTabChange"
      >
        {{item}}
      </view>
    </view>
    <view class="header-actions">
      <view class="search-btn" bindtap="showSearch">
        <text>🔍</text>
      </view>
      <view class="debug-btn" bindtap="goToAdmin">调试</view>
    </view>
  </view>

  <view class="search-bar" wx:if="{{showSearchBar}}">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索影片名称" 
        value="{{searchKeyword}}" 
        bindinput="onSearchInput" 
        bindconfirm="onSearchConfirm"
        focus="{{showSearchBar}}"
      />
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
    </view>
    <text class="search-cancel" bindtap="hideSearch">取消</text>
  </view>

  <view class="sub-tabs">
    <view 
      class="sub-item {{currentSub === index ? 'active' : ''}}" 
      wx:for="{{subCategories}}" 
      wx:key="index"
      data-index="{{index}}"
      bindtap="onSubChange"
    >
      <text class="sub-name">{{item}}</text>
    </view>
  </view>

  <view class="list-container">
    <block wx:if="{{!loading || list.length > 0}}">
      <view class="movie-list">
        <view 
          class="movie-item" 
          wx:for="{{list}}" 
          wx:key="_id"
          data-index="{{index}}"
          bindtap="showDetail"
        >
          <view class="rank">{{index + 1}}</view>
          <view class="poster-wrap">
            <image 
              wx:if="{{item.poster}}" 
              class="poster" 
              src="{{item.poster}}" 
              mode="aspectFill" 
              lazy-load 
              binderror="onPosterError" 
              data-index="{{index}}" 
            />
            <view wx:else class="poster-placeholder">
              <text>{{item.title[0]}}</text>
            </view>
          </view>
          <view class="info">
            <view class="title-row">
              <text class="title">{{item.title}}</text>
              <view class="score-col">
                <view class="hot-score" wx:if="{{item.hotScore > 0}}">
                  <text class="hot-icon">🔥</text>
                  <text class="hot-value">{{item.hotScore}}</text>
                </view>
                <text class="rating" wx:if="{{item.rating > 0}}">★ {{item.rating}}</text>
              </view>
            </view>
            <view class="meta">
              <text>{{item.year}}</text>
            </view>
            <view class="cast-row" wx:if="{{item.castDisplay}}">
              <text class="cast-text">{{item.castDisplay}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="loading-more" wx:if="{{loading}}">
        <text class="loading-text">服务器摸鱼中</text>
        <image class="emoji-bounce" src="/images/loading.png" mode="aspectFit" />
        <image class="emoji-bounce delay-1" src="/images/loading.png" mode="aspectFit" />
        <image class="emoji-bounce delay-2" src="/images/loading.png" mode="aspectFit" />
      </view>
      
      <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">
        <text>— 已加载全部 —</text>
      </view>
      
      <view class="refresh-time" wx:if="{{refreshAt && list.length > 0 && !isSearching}}">
        <text>榜单更新于 {{refreshAt}}</text>
      </view>
    </block>

    <view class="empty" wx:if="{{!loading && list.length === 0}}">
      <view class="empty-icon">📭</view>
      <text class="empty-title">暂无数据</text>
      <text class="empty-desc">该分类下还没有内容</text>
      <view class="empty-btn" bindtap="goToAdmin">去导入数据</view>
    </view>

    <view class="loading-wrap" wx:if="{{loading && list.length === 0}}">
      <text class="loading-text">服务器摸鱼中</text>
      <image class="emoji-bounce" src="/images/loading.png" mode="aspectFit" />
      <image class="emoji-bounce delay-1" src="/images/loading.png" mode="aspectFit" />
      <image class="emoji-bounce delay-2" src="/images/loading.png" mode="aspectFit" />
    </view>
  </view>
</view>

<view class="card-mask" wx:if="{{showDetailCard}}" bindtap="hideDetail" catchtouchmove="true">
  <scroll-view class="detail-card" scroll-y catchtap="preventBubble">
    <view class="card-header">
      <image wx:if="{{detailItem.poster}}" class="card-poster" src="{{detailItem.poster}}" mode="aspectFill" />
      <view wx:else class="card-poster-placeholder">
        <text>{{detailItem.title[0]}}</text>
      </view>
      <view class="card-info">
        <text class="card-title">{{detailItem.title}}</text>
        <view class="card-meta-row">
          <text class="card-rating" wx:if="{{detailItem.rating > 0}}">★ {{detailItem.rating}}</text>
          <text class="card-meta-item" wx:if="{{detailItem.year}}">{{detailItem.year}}</text>
          <text class="card-meta-item" wx:if="{{detailItem.subCategory}}">{{detailItem.subCategory}}</text>
        </view>
        <view class="card-tags" wx:if="{{detailItem.genres && detailItem.genres.length > 0}}">
          <text class="card-tag" wx:for="{{detailItem.genres}}" wx:key="*this" wx:if="{{index < 4}}">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="card-section" wx:if="{{detailItem.cast && detailItem.cast.length > 0}}">
      <text class="card-section-title">演职人员</text>
      <view class="card-cast-list">
        <text class="card-cast-item" wx:for="{{detailItem.cast}}" wx:key="*this" wx:if="{{index < 6}}">{{item}}</text>
      </view>
    </view>

    <view class="card-section" wx:if="{{detailItem.director}}">
      <text class="card-section-title">导演</text>
      <text class="card-director">{{detailItem.director}}</text>
    </view>

    <view class="card-section" wx:if="{{detailItem.description}}">
      <text class="card-section-title">内容简介</text>
      <text class="card-desc">{{detailItem.description}}</text>
    </view>

    <view class="card-close-hint">
      <text>点击空白处关闭</text>
    </view>
  </scroll-view>
</view>
