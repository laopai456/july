<view class="container" hidden="{{showDetailCard}}">
  <view class="header">
    <view class="tabs">
      <view 
        class="tab-item {{currentTab === index ? 'active' : ''}}" 
        wx:for="{{tabs}}" 
        wx:key="index"
        data-index="{{index}}"
        bindtap="onTabChange"
      >
        {{item}}
      </view>
    </view>
    <view class="header-actions">
      <view class="search-btn" bindtap="showSearch">
        <text>🔍</text>
      </view>
      <view class="debug-btn" bindtap="goToAdmin">调试</view>
    </view>
  </view>

  <view class="search-bar" wx:if="{{showSearchBar}}">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索影片名称" 
        value="{{searchKeyword}}" 
        bindinput="onSearchInput" 
        bindconfirm="onSearchConfirm"
        focus="{{showSearchBar}}"
      />
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
    </view>
    <text class="search-cancel" bindtap="hideSearch">取消</text>
  </view>

  <view class="sub-tabs">
    <view 
      class="sub-item {{currentSub === index ? 'active' : ''}}" 
      wx:for="{{subCategories}}" 
      wx:key="index"
      data-index="{{index}}"
      bindtap="onSubChange"
    >
      <text class="sub-name">{{item}}</text>
    </view>
  </view>

  <view class="list-container">
    <block wx:if="{{!loading || list.length > 0}}">
      <view class="movie-list">
        <view 
          class="movie-item" 
          wx:for="{{list}}" 
          wx:key="_id"
          data-index="{{index}}"
          bindtap="showDetail"
        >
          <view class="rank">{{index + 1}}</view>
          <view class="poster-wrap">
            <image 
              wx:if="{{item.poster}}" 
              class="poster" 
              src="{{item.poster}}" 
              mode="aspectFill" 
              lazy-load 
              binderror="onPosterError" 
              data-index="{{index}}" 
            />
            <view wx:else class="poster-placeholder">
              <text>{{item.title[0]}}</text>
            </view>
          </view>
          <view class="info">
            <view class="title-row">
              <text class="title">{{item.title}}</text>
              <view class="score-col">
                <view class="hot-score" wx:if="{{item.hotScore > 0}}">
                  <text class="hot-icon">🔥</text>
                  <text class="hot-value">{{item.hotScore}}</text>
                </view>
                <text class="rating" wx:if="{{item.rating > 0}}">★ {{item.rating}}</text>
              </view>
            </view>
            <view class="meta">
              <text>{{item.year}}</text>
            </view>
            <view class="cast-row" wx:if="{{item.castDisplay}}">
              <text class="cast-text">{{item.castDisplay}}</text>
            </view>
          </view>
        </view>
      </view>
      
      <view class="loading-more" wx:if="{{loading}}">
        <text class="loading-text">服务器摸鱼中</text>
        <image class="emoji-bounce" src="/images/loading.png" mode="aspectFit" />
        <image class="emoji-bounce delay-1" src="/images/loading.png" mode="aspectFit" />
        <image class="emoji-bounce delay-2" src="/images/loading.png" mode="aspectFit" />
      </view>
      
      <view class="no-more" wx:if="{{!hasMore && list.length > 0}}">
        <text>— 已加载全部 —</text>
      </view>
      
      <view class="refresh-time" wx:if="{{refreshAt && list.length > 0 && !isSearching}}">
        <text>榜单更新于 {{refreshAt}}</text>
      </view>
    </block>

    <view class="empty" wx:if="{{!loading && list.length === 0}}">
      <view class="empty-icon">📭</view>
      <text class="empty-title">暂无数据</text>
      <text class="empty-desc">该分类下还没有内容</text>
      <view class="empty-btn" bindtap="goToAdmin">去导入数据</view>
    </view>

    <view class="loading-wrap" wx:if="{{loading && list.length === 0}}">
      <text class="loading-text">服务器摸鱼中</text>
      <image class="emoji-bounce" src="/images/loading.png" mode="aspectFit" />
      <image class="emoji-bounce delay-1" src="/images/loading.png" mode="aspectFit" />
      <image class="emoji-bounce delay-2" src="/images/loading.png" mode="aspectFit" />
    </view>
  </view>
</view>

<view class="card-mask" hidden="{{!showDetailCard}}" bindtap="hideDetail">
  <view class="detail-card" catchtap="preventBubble">
    <scroll-view scroll-y class="card-scroll">
      <view class="card-header">
        <text class="card-title">{{detailItem.title}}</text>
        <view class="card-rating" wx:if="{{detailItem.rating > 0}}">
          <text class="rating-star">★</text>
          <text class="rating-num">{{detailItem.rating}}</text>
        </view>
      </view>

      <view class="card-tags">
        <text class="tag" wx:if="{{detailItem.year}}">{{detailItem.year}}</text>
        <text class="tag" wx:for="{{detailItem.genres}}" wx:if="{{item}}" wx:key="*this">{{item}}</text>
        <text class="tag region-tag" wx:if="{{detailItem.region}}">{{detailItem.region === 'cn' ? '华语' : detailItem.region === 'kr' ? '韩国' : detailItem.region === 'jp' ? '日本' : item.region}}</text>
      </view>

      <view class="card-info-row" wx:if="{{detailItem.director}}">
        <text class="info-label">导演</text>
        <text class="info-value">{{detailItem.director}}</text>
      </view>

      <view class="card-info-row" wx:if="{{detailItem.castDisplay}}">
        <text class="info-label">演员</text>
        <text class="info-value">{{detailItem.castDisplay}}</text>
      </view>

      <view class="card-divider"></view>

      <view class="card-desc-wrap" wx:if="{{detailItem.description}}">
        <text class="card-desc {{descExpanded ? '' : 'collapsed'}}">{{detailItem.description}}</text>
        <view class="expand-btn" wx:if="{{detailItem.description.length > 80}}" bindtap="toggleDesc">
          <text>{{descExpanded ? '收起' : '展开全部'}}</text>
        </view>
      </view>

      <text class="card-desc" wx:else>暂无简介</text>
    </scroll-view>
  </view>
</view>
