.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #e8f4fc 0%, #fce8f0 100%);
  padding-bottom: 40rpx;
}

.poster-section {
  width: 100%;
  height: 500rpx;
  position: relative;
}

.poster-section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(to top, rgba(232, 244, 252, 1), transparent);
}

.poster {
  width: 100%;
  height: 100%;
}

.info-section {
  margin: -40rpx 30rpx 20rpx 30rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 8rpx 8rpx 20rpx #c8d8e8, -8rpx -8rpx 20rpx #ffffff;
  position: relative;
  z-index: 10;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 300;
  color: #5a6a7a;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.title-en {
  display: block;
  font-size: 24rpx;
  color: #9aa8b8;
  margin-bottom: 24rpx;
  font-weight: 300;
}

.meta-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.rating {
  font-size: 40rpx;
  background: linear-gradient(135deg, #f8b4c4, #a8d4f0);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 500;
  margin-right: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #8a9aaa;
  margin-right: 16rpx;
  font-weight: 300;
}

.tags {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  color: #7a8a9a;
  background: linear-gradient(145deg, #f5faff, #e8f0f0);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  box-shadow: 3rpx 3rpx 6rpx #d0dae4, -3rpx -3rpx 6rpx #ffffff;
  font-weight: 300;
}

.section {
  margin: 20rpx 30rpx;
  padding: 36rpx;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 8rpx 8rpx 20rpx #c8d8e8, -8rpx -8rpx 20rpx #ffffff;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: #6a7a8a;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(200, 216, 232, 0.5);
}

.description {
  font-size: 26rpx;
  color: #7a8a9a;
  line-height: 1.9;
  font-weight: 300;
  letter-spacing: 1rpx;
}

.cast-list {
  display: flex;
  flex-wrap: wrap;
}

.cast-item {
  font-size: 24rpx;
  color: #6a7a8a;
  background: linear-gradient(145deg, #f5faff, #e8f0f0);
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  margin-right: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 4rpx 4rpx 8rpx #d0dae4, -4rpx -4rpx 8rpx #ffffff;
  font-weight: 300;
}

.director {
  font-size: 26rpx;
  color: #6a7a8a;
  font-weight: 300;
}

.loading-wrap,
.error-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #9aa8b8;
  font-size: 28rpx;
  font-weight: 300;
}

.loading-wrap {
  margin: 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c8d8e8, -6rpx -6rpx 12rpx #ffffff;
}

.error-wrap {
  margin: 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f0f8ff, #e8f0f0);
  box-shadow: 6rpx 6rpx 12rpx #c8d8e8, -6rpx -6rpx 12rpx #ffffff;
}
